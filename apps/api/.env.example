# Evercrafted API — environment variables
# Copy this file to .env and fill in values. Never commit .env.

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=postgresql://postgres:password@localhost:5432/evercrafted

# Anthropic API key — server-side ONLY, never expose to frontend
ANTHROPIC_API_KEY=sk-ant-...

JWT_SECRET=changeme-use-a-long-random-string-in-production

# Used by the Next.js frontend to reach this API
NEXT_PUBLIC_API_URL=http://localhost:8000
